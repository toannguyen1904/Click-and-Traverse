<mujoco model="g1 scene catra mesh">
    <!-- EVAL SCENE TEMPLATE. Never loaded directly — always patched first by set_scene_for_xml().
         Contains obstacle mesh (hardcoded to narrow1/obs.obj as placeholder), lights, and full
         contact pairs (hand/torso/pelvis/head <-> floor and box).
         Patched copy is written to scene_mjx_feetonly_mesh_catra_tmp.xml at eval time.
         Used by PlayG1PickupEnv (CPU MuJoCo viewer / ONNX play). -->
    <include file="g1_mjx_feetonly_torque_catra.xml"/>

    <statistic center="0 0 0.7" extent="1.2" meansize="0.04"/>

    <visual>
        <headlight diffuse=".8 .8 .8" ambient=".2 .2 .2" specular="1 1 1"/>
        <rgba force="1 0 0 1"/>
        <global azimuth="140" elevation="-20"/>
        <map force="0.01"/>
        <scale forcewidth="0.3" contactwidth="0.5" contactheight="0.2"/>
        <quality shadowsize="8192"/>
    </visual>

    <sensor>
        <gyro name="imu-torso-angular-velocity" site="imu_in_torso" noise="5e-4" cutoff="34.9"/>
        <accelerometer name="imu-torso-linear-acceleration" site="imu_in_torso" noise="1e-2" cutoff="157"/>
        <gyro name="imu-pelvis-angular-velocity" site="imu_in_pelvis" noise="5e-4" cutoff="34.9"/>
        <accelerometer name="imu-pelvis-linear-acceleration" site="imu_in_pelvis" noise="1e-2" cutoff="157"/>
    </sensor>

    <asset>
        <texture type="skybox" builtin="gradient"
                 rgb1="0.95 0.97 1.00" rgb2="0.70 0.80 0.95"
                 width="1024" height="1024"/>
        <texture name="groundplane" type="2d" builtin="checker"
                 rgb1="0.35 0.36 0.37" rgb2="0.28 0.29 0.30"
                 width="1024" height="1024"
                 mark="none"/>
        <material name="groundplane" texture="groundplane"
                  texuniform="true"
                  texrepeat="60 60"
                  reflectance="0.01"
                  specular="0.25"
                  shininess="0.35"/>
        <texture name="tex_brick_cube" type="2d"
                 file="texture.png"/>
        <material name="mat_brick_cube"
                  texture="tex_brick_cube"
                  reflectance="0.10"
                  specular="0.20"
                  shininess="0.30"/>
        <mesh name="scene_mesh" file="../TypiObs/narrow1/obs.obj"/>
    </asset>

    <worldbody>
        <light name="key" pos="0 0 5" dir="0 0 -1" directional="true"/>
        <light name="fill" pos="3 -3 3" dir="-1 1 -1" directional="true"/>
        <body name="scene" pos="-0.5 -1.0 0">
            <!-- contype/conaffinity=8 (bit-3): isolated bit, so the obstacle mesh does NOT
                 auto-collide with the box (bits 0+1), floor (bits 0+2), or support (bits 1+2).
                 Robot-obstacle interaction is handled via HumanoidPF fields, not physical contact. -->
            <geom type="mesh" mesh="scene_mesh" rgba="0.7 0.7 0.7 1" contype="8" conaffinity="8" material="mat_brick_cube"/>
        </body>
        <geom name="floor" size="0 0 0.01" type="plane" material="groundplane" contype="5" conaffinity="5"/>
        <!-- Box body with freejoint; rests on box_support surface. Position set by env reset.
             contype=3 (bits 0+1): bit-0 -> robot contacts, bit-1 -> support contact. -->
        <body name="carried_box" pos="0.35 0 1.0">
            <freejoint name="box_joint"/>
            <geom name="box_geom" type="box" size="0.15 0.2 0.15"
                  contype="3" conaffinity="3" condim="3" friction="2.0 0.5 0.5"
                  rgba="0.2 0.4 0.9 1" mass="1.5"/>
            <site name="box_center" pos="0 0 0" size="0.02"/>
        </body>
        <!-- Support surface: freejoint body (not mocap) so MJX contact detection works.
             Repositioned via qpos in env reset; velocity zeroed each step to pin it.
             mass=1000 makes it effectively immovable under box/robot contact forces.
             contype=2/conaffinity=2 (bit-1 only): collides with box but not robot or floor. -->
        <body name="box_support" pos="0.35 0 0.3">
            <freejoint name="support_joint"/>
            <geom name="box_support_col" type="box" size="0.2 0.25 0.3"
                  contype="6" conaffinity="6" condim="3"
                  mass="1000" rgba="0.45 0.30 0.15 0.3"/>
        </body>
    </worldbody>

    <contact>
        <!-- Robot-box contacts (temporarily disabled) -->
        <pair geom1="left_hand_collision"           geom2="box_geom" condim="3" friction="2.0 0.5 0.5"/>
        <pair geom1="right_hand_collision"          geom2="box_geom" condim="3" friction="2.0 0.5 0.5"/>
        <pair geom1="left_wrist_collision"          geom2="box_geom" condim="3" friction="1.0 0.5 0.5"/>
        <pair geom1="right_wrist_collision"         geom2="box_geom" condim="3" friction="1.0 0.5 0.5"/>
        <pair geom1="left_elbow_collision"          geom2="box_geom" condim="3" friction="0.5 0.5 0.5"/>
        <pair geom1="right_elbow_collision"         geom2="box_geom" condim="3" friction="0.5 0.5 0.5"/>
        <pair geom1="left_shoulder_yaw_collision"   geom2="box_geom" condim="3" friction="0.5 0.5 0.5"/>
        <pair geom1="right_shoulder_yaw_collision"  geom2="box_geom" condim="3" friction="0.5 0.5 0.5"/>
        <pair geom1="torso_collision"               geom2="box_geom" condim="3" friction="0.5 0.5 0.5"/>
        <pair geom1="head_collision"                geom2="box_geom" condim="3" friction="0.5 0.5 0.5"/>

        <!-- Floor contacts for body parts that have no default floor collision -->
        <pair geom1="left_shin"            geom2="floor"      condim="3" friction="0.5 0.5"/>
        <pair geom1="right_shin"           geom2="floor"      condim="3" friction="0.5 0.5"/>
        <pair geom1="left_thigh"           geom2="floor"      condim="3" friction="0.5 0.5"/>
        <pair geom1="right_thigh"          geom2="floor"      condim="3" friction="0.5 0.5"/>
        <pair geom1="left_hand_collision"  geom2="floor"      condim="3" friction="0.5 0.5"/>
        <pair geom1="right_hand_collision" geom2="floor"      condim="3" friction="0.5 0.5"/>
        <pair geom1="pelvis_collision"     geom2="floor"      condim="3" friction="0.5 0.5"/>
        <pair geom1="torso_collision"      geom2="floor"      condim="3" friction="0.5 0.5"/>
        <pair geom1="head_collision"       geom2="floor"      condim="3" friction="0.5 0.5"/>
    </contact>

</mujoco>
